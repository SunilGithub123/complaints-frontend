{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^api:gen"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "api:gen": {
      "inputs": ["packages/api/openapi.json", "packages/api/orval.config.ts"],
      "outputs": ["packages/api/src/generated/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}


as/MarkDuplicateRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/staff/complaints/{id}/close":{"post":{"tags":["Staff Complaint Management"],"summary":"Engineer / Admin close-on-behalf of a RESOLVED complaint","description":"Returns the post-close detail (status=CLOSED + bumped version) so the FE can update its cache in one round-trip without a follow-up GET.","operationId":"close","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CloseComplaintRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseComplaintStaffDetailResponse"}}}}}}},"/api/v1/staff/complaints/{id}/assign":{"post":{"tags":["Staff Complaint Management"],"summary":"Assign a SUBMITTED complaint to a technician and set severity","operationId":"assign","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignComplaintRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/staff/auth/refresh":{"post":{"tags":["Staff Auth"],"summary":"Rotate refresh token; returns new access + refresh pair","operationId":"refresh","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefreshTokenRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseLoginResponse"}}}}}}},"/api/v1/staff/auth/logout":{"post":{"tags":["Staff Auth"],"summary":"Revoke the provided refresh token (or all sessions if body omitted)","operationId":"logout","requestBody":{"content":{"ap